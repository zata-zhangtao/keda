# Dependencies
node_modules/

# Build output
dist/
build/
site/

# Cache
.npm/
.eslintcache
*.tsbuildinfo

# Frontend framework artifacts (各前端自带 .gitignore 也覆盖，这里冗余兜底)
.next/
.tanstack/
.vitest-attachments/

# Environment files - ignore all .env* except *.env*.example
.env*
!.env*.example

# Preview deployment runtime env files
deploy/vps-traefik/*.env
!deploy/vps-traefik/*.env.example

# Testing
coverage/

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Claude planning session archives (local state, not for VCS)
.local/state/gh/device-id

# Realistic validation evidence and runner state (local only)
.iar
.agent-runner/

# Realistic Validation evidence packages — local PRD flow (`just ai implement`).
# Commit only the text reports (*.md: verification-plan / evidence-report /
# verifier-report); keep raw artifacts (screenshots, recordings, captured
# output, large logs) local-only. Same principle as the iar runner's
# .iar/evidence/: raw evidence never enters code history (binary bloat + secret
# leakage in permanent git history). The verifier and check_prd_evidence.sh
# still run against the local files at implement time.
tasks/evidence/**
!tasks/evidence/**/
!tasks/evidence/**/*.md

# pytest-testmon SQLite cache
.testmondata*

# >>> iar (managed by `iar init`) >>>
# Realistic Validation evidence (worktree-local)
.iar/

# IAR-managed git worktrees (host-local)
.iar-worktrees/
# <<< iar <<<
