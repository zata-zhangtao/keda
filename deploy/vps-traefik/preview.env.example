# -----------------------------------------------------------------------------
# Preview Deployment Environment Template (non-sensitive structure only)
# -----------------------------------------------------------------------------
# Copy this file to a temporary location and fill in the values generated by
# scripts/preview_env.py. Real secrets (POSTGRES_PASSWORD, etc.) must come from
# GitHub Secrets / your secret management system and never be committed.
# -----------------------------------------------------------------------------

# Preview domain and project isolation
PREVIEW_DOMAIN=pr-123.preview.example.com
COMPOSE_PROJECT_NAME=keda-pr-123
APP_DIR=/opt/preview/keda-pr-123
PREVIEW_URL_SCHEME=https

# Container images (SHA tags generated by the deploy-preview workflow)
BACKEND_IMAGE=ghcr.io/zata-zhangtao/keda-backend:deadbee
FRONTEND_IMAGE=ghcr.io/zata-zhangtao/keda-frontend:deadbee
REGISTRY_HOST=ghcr.io
REGISTRY_NAMESPACE=zata-zhangtao

# Traefik integration
TRAEFIK_NETWORK=traefik
TRAEFIK_ROUTER_NAME=keda-pr-123
TRAEFIK_SERVICE_NAME=keda-pr-123

# Ephemeral preview database
POSTGRES_USER=keda
POSTGRES_PASSWORD=change-me-in-secrets
POSTGRES_DB=keda_preview
DATABASE_URL=postgresql+psycopg2://keda:change-me-in-secrets@db:5432/keda_preview
