+# Internal: fix git rebase/merge conflicts with an AI tool.
+_ai_fix ai_tool="claude" prompt="" :
+    #!/usr/bin/env bash
+    set -euo pipefail
+
+    ai_tool="{{ai_tool}}"
+    prompt_text="{{prompt}}"
+
+    # Check if a rebase or merge is in progress
+    rebase_dir=""
+    if [ -d "$(git rev-parse --git-dir)/rebase-merge" ]; then
+        rebase_dir="$(git rev-parse --git-dir)/rebase-merge"
+    elif [ -d "$(git rev-parse --git-dir)/rebase-apply" ]; then
+        rebase_dir="$(git rev-parse --git-dir)/rebase-apply"
+    fi
+
+    if [ -z "$rebase_dir" ]; then
+        echo "No rebase or merge in progress."
+        exit 0
+    fi
+
+    # List unmerged files
+    unmerged_files="$(git diff --name-only --diff-filter=U 2>/dev/null || true)"
+    if [ -z "$unmerged_files" ]; then
+        echo "No conflict files found — all clear."
+        exit 0
+    fi
+
+    echo "Conflicts in:"
+    printf '%s\n' "$unmerged_files"
+    echo ""
+
+    # Auto-generate default prompt
+    if [ -z "$prompt_text" ]; then
+        prompt_text="Resolve all git rebase conflicts. For each conflict file, read it, merge correctly preserving the intent of both sides where possible, remove all conflict markers, then git add the resolved file. Do NOT commit — just stage. After all files are done, run git diff --cached to show what you resolved. Finally, run 'just test' and ensure it passes."
+    fi
+
+    echo "Tool: $ai_tool"
+    echo "Prompt: $prompt_text"
+    echo ""
+
+    # Run AI tool via user's interactive shell (needed for alias resolution)
+    if [ "$ai_tool" = "kimi" ]; then
+        # kimi uses --prompt flag instead of positional argument
+        "${SHELL:-bash}" -i -c "$(printf '%s --prompt %q' "$ai_tool" "$prompt_text")" || true
+    elif [ "$ai_tool" = "claude" ]; then
+        # claude: --print + --verbose + stream-json lets jq render thinking/tool calls in real time
+        claude --dangerously-skip-permissions --print --verbose --output-format stream-json --include-partial-messages < <(printf '%s' "$prompt_text") 2>&1 | \
+            jq --unbuffered -r '
+                if .type == "stream_event" and .event.type == "content_block_delta" and .event.delta.type == "thinking_delta" then
+                    "💭 \(.event.delta.thinking)\n"
+                elif .type == "stream_event" and .event.type == "content_block_start" and .event.content_block.type == "tool_use" then
+                    "\n🔧 \(.event.content_block.name)(\((.event.content_block.input // {} | tostring) | .[0:120]))\n"
+                elif .type == "result" then
+                    "\n\(.result)\n"
+                else
+                    empty
+                end
+            ' || true
+    else
+        "${SHELL:-bash}" -i -c "$(printf '%s %q' "$ai_tool" "$prompt_text")" || true
+    fi
