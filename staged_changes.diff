+        claude --dangerously-skip-permissions --print --verbose --output-format stream-json --include-partial-messages < <(printf '%s' "$prompt_text") 2>&1 | \
+            jq --unbuffered -r '
+                if .type == "stream_event" and .event.type == "content_block_delta" and .event.delta.type == "thinking_delta" then
+                    "💭 \(.event.delta.thinking)\n"
+                elif .type == "stream_event" and .event.type == "content_block_start" and .event.content_block.type == "tool_use" then
+                    "\n🔧 \(.event.content_block.name)(\((.event.content_block.input // {} | tostring) | .[0:120]))\n"
+                elif .type == "result" then
+                    "\n\(.result)\n"
+                else
+                    empty
+                end
+            ' || true
+    else
+        "${SHELL:-bash}" -i -c "$(printf '%s %q' "$ai_tool" "$prompt_text")" || true
+    fi
+
+    # AI finished - now handle push with safety checks and user confirmation.
+    echo ""
+    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
+    echo "🤖 AI finished. Preparing to push..."
+    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
+    echo ""
+
+    current_branch="$(git rev-parse --abbrev-ref HEAD)"
+    upstream="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
+
+    if [ -z "$upstream" ]; then
+        # No upstream - ask user to set up
+        remote="$(git remote | head -1)"
+        if [ -z "$remote" ]; then
+            echo "ERROR: Branch '$current_branch' has no upstream and no git remote is configured."
+            echo "Add a remote first, e.g.: git remote add origin <url>"
+            exit 1
+        fi
+
+        echo "Branch '$current_branch' has no upstream."
+        read -r -p "Push to '$remote/$current_branch' and set upstream? [Y/n] " confirm
