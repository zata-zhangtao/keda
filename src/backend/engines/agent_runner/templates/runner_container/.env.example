# -----------------------------------------------------------------------------
# iar Runner container environment template
#
# Copy this file to `.env` next to docker-compose.runner.yml and fill in the
# non-empty values. ``iar container up`` will pass REPO_PATH / GH_TOKEN /
# RUNNER_UID / RUNNER_GID / IAR_REPO_ID via the command line, overriding any
# value you put here — the .env is only used when invoking
# `docker compose` directly without going through iar.
#
# Rules (see CLAUDE.md):
#   - Non-sensitive defaults are commented out (KEY=default), so a fresh
#     install loads with sane defaults.
#   - Sensitive keys (GH_TOKEN) stay uncommented with empty values so the
#     variable name is visible and a missing value triggers an obvious
#     auth failure instead of a silent default.
# -----------------------------------------------------------------------------

# Target repository path (absolute path on the host).
# REPO_PATH=/absolute/path/to/your/repo

# Repository registry id (matches [agent_runner.repositories.<id>] in config.toml).
# Used by `iar container up --repo-id <id>` to enable host daemon mutual exclusion.
# REPO_ID=keda

# Host UID/GID to run the container as. ``iar container up`` injects these
# automatically from os.getuid()/os.getgid(); only override if you need a
# different owner (e.g. shared runner pool).
# RUNNER_UID=1000
# RUNNER_GID=1000

# GitHub token used by the container's `gh` CLI. macOS keychain is not
# reachable from inside the container; use a PAT or a CI token.
# Regenerate with `gh auth token` and paste here, or set GH_TOKEN in your
# shell before running `iar container up`.
GH_TOKEN=
