# syntax=docker/dockerfile:1.6
# -----------------------------------------------------------------------------
# iar Runner Dockerfile
#
# 为 ``iar container up`` 构建的 runner 镜像：预装 claude / codex / kimi 三个
# agent CLI、gh CLI、Node.js、uv、just、git，并在镜像里安装 iar 自身。
#
# 构建参数：
#   KEDA_VERSION   —— 安装的 keda / iar 版本；默认 latest；显式传 "editable"
#                    时改走本地源码 editable 安装（开发模式）
#   KEDA_LOCAL_SRC —— 仅在 KEDA_VERSION=editable 时使用，指向本地 keda 源码
#                    根目录（绝对路径）
#   CLAUDE_VERSION / CODEX_VERSION / KIMI_VERSION —— 三个 agent CLI 的 npm
#                    / 二进制版本；通过 ARG 参数化便于升级。
# -----------------------------------------------------------------------------

FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    DEBIAN_FRONTEND=noninteractive \
    PATH="/home/runner/.local/bin:/usr/local/bin:/usr/bin:/bin:$PATH" \
    LOG_DIR="/home/runner/.iar/logs"

# 可调 agent CLI 版本；保持 ARG 化便于升级与重 build。
ARG CLAUDE_VERSION=2.1.187
ARG CODEX_VERSION=0.142.4
ARG KIMI_VERSION=0.22.3
ARG NODE_MAJOR=22
# KEDA_VERSION 接受 git tag 或 commit SHA；默认 main（开发迭代期方便）。
ARG KEDA_VERSION=main

# 一次性安装系统级依赖：curl / git / ca-certificates / gnupg（gh 需要）。
# 先准备 apt 源供 gh / Node 安装，再清理 apt 缓存减小镜像。
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        gnupg \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x \
        | bash - \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        gh \
        nodejs \
    && rm -rf /var/lib/apt/lists/*

# 安装 just（cargo 编译较慢；从官方预编译二进制下载，二进制无依赖）。
# tag_name 自 just 1.x 起不带 v 前缀，用 python 解 JSON 拿版本；按 dpkg 架构
# 选择 aarch64 / x86_64 musl 静态链接二进制（无 glibc 依赖）。
RUN set -eux; \
    JUST_VERSION=$(curl -fsSL https://api.github.com/repos/casey/just/releases/latest \
        | python3 -c 'import json,sys; print(json.load(sys.stdin)["tag_name"].lstrip("v"))'); \
    JUST_ARCH=$(dpkg --print-architecture); \
    case "${JUST_ARCH}" in \
        amd64) JUST_TARGET="x86_64-unknown-linux-musl" ;; \
        arm64) JUST_TARGET="aarch64-unknown-linux-musl" ;; \
        *) echo "Unsupported architecture for just: ${JUST_ARCH}"; exit 1 ;; \
    esac; \
    curl -fsSL -o /tmp/just.tar.gz \
        "https://github.com/casey/just/releases/download/${JUST_VERSION}/just-${JUST_VERSION}-${JUST_TARGET}.tar.gz" \
    && tar -xzf /tmp/just.tar.gz -C /tmp just \
    && mv /tmp/just /usr/local/bin/just \
    && chmod +x /usr/local/bin/just \
    && rm /tmp/just.tar.gz \
    && just --version

# 安装 uv（与 backend Dockerfile 同模式）。
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
    && mv /root/.local/bin/uv /usr/local/bin/uv

# 安装 gosu（容器内 su/sudo 的轻量替代，专门为 entrypoint 设计）。
# 从官方 release 下载单文件二进制；不验签（容器构建内无 gpg trust setup，
# 走 sha256 校验已经覆盖完整性——二进制是 tianon/gosu 官方项目固定 release）。
RUN set -eux; \
    ARCH=$(dpkg --print-architecture); \
    curl -fsSL -o /usr/local/bin/gosu \
        "https://github.com/tianon/gosu/releases/download/1.17/gosu-${ARCH}" \
    && chmod +x /usr/local/bin/gosu \
    && gosu --version

# 安装 claude / codex：均为 npm 全局包。
RUN npm install -g \
        @anthropic-ai/claude-code@${CLAUDE_VERSION} \
        @openai/codex@${CODEX_VERSION} \
    && npm cache clean --force

# 安装 kimi：从 MoonshotAI/kimi-code 仓库下载 Linux 预编译二进制（zip）。
# kimi 官方安装脚本 ``kimi-cli.moonshot.ai/install.sh`` 在 sandbox 内不可达，
# 改用 GitHub release 的 linux-arm64 / linux-x64 zip；按 dpkg 架构自适配。
# ``@moonshot-ai/kimi-code@0.22.3`` 是 PRD 钉版本，避免 npm 注册表 tag 漂移。
RUN set -eux; \
    KIMI_TAG="@moonshot-ai/kimi-code@${KIMI_VERSION}"; \
    KIMI_ARCH=$(dpkg --print-architecture); \
    case "${KIMI_ARCH}" in \
        amd64) KIMI_TARGET="linux-x64" ;; \
        arm64) KIMI_TARGET="linux-arm64" ;; \
        *) echo "Unsupported architecture for kimi: ${KIMI_ARCH}"; exit 1 ;; \
    esac; \
    curl -fsSL -o /tmp/kimi.zip \
        "https://github.com/MoonshotAI/kimi-code/releases/download/${KIMI_TAG}/kimi-code-${KIMI_TARGET}.zip" \
    && python3 -m zipfile -e /tmp/kimi.zip /opt/kimi \
    && mv /opt/kimi/kimi /usr/local/bin/kimi \
    && chmod +x /usr/local/bin/kimi \
    && rm -rf /tmp/kimi.zip /opt/kimi

# 建 non-root 用户；runtime UID/GID 由 compose 注入对齐宿主，避免污染宿
# 主文件属主为 root。HOME 必须是 /home/runner，对应 compose 内的挂载路径。
# ``/home/runner`` 设为 0755 而非 useradd 默认 0700：entrypoint 需要在切到
# ``RUNNER_UID``（可能 != 1000）前能 stat 该目录做存在性检查。
RUN groupadd -g 1000 runner || true \
    && useradd -m -u 1000 -g runner -s /bin/bash runner \
    && chmod 0755 /home/runner

# 安装 keda（iar 自身）。默认从 GitHub 源码安装（keda 暂未发布 PyPI / release
# tarball，PyPI 上也没有 ``keda`` 包）；通过 git tag 钉版本。开发模式
# （KEDA_VERSION=editable + KEDA_LOCAL_SRC）走本地源码 editable 安装。
ARG KEDA_LOCAL_SRC=""
USER root
RUN set -eux; \
    mkdir -p /opt/keda && cd /opt/keda \
        && uv venv .venv --python 3.13 \
        && . .venv/bin/activate; \
    if [ "${KEDA_VERSION}" = "editable" ] && [ -n "${KEDA_LOCAL_SRC}" ]; then \
        echo "Installing keda from local source: ${KEDA_LOCAL_SRC}"; \
        . .venv/bin/activate \
            && uv pip install -e "${KEDA_LOCAL_SRC}"; \
    else \
        echo "Installing keda from git tag: ${KEDA_VERSION}"; \
        . .venv/bin/activate \
            && uv pip install "keda @ git+https://github.com/zata-zhangtao/keda.git@${KEDA_VERSION}"; \
    fi; \
    echo "/opt/keda/.venv/bin" > /etc/profile.d/keda-path.sh
USER runner

# 复制 entrypoint（root 阶段：/usr/local/bin 必须 root 可写；后续 chmod 也在 root）。
USER root
COPY entrypoint.sh /usr/local/bin/iar-runner-entrypoint.sh
RUN chmod +x /usr/local/bin/iar-runner-entrypoint.sh

# 预创建 runtime 目录。
RUN mkdir -p /home/runner/.iar /home/runner/.iar/logs \
    && chown -R runner:runner /home/runner

ENV PATH="/opt/keda/.venv/bin:${PATH}" \
    HOME="/home/runner" \
    IAR_HOME="/home/runner/.iar"

WORKDIR /workspace/repo

ENTRYPOINT ["/usr/local/bin/iar-runner-entrypoint.sh"]

# 默认 CMD：daemon 模式轮询；compose 可在 command 段覆盖（保留 hook）。
CMD ["iar", "daemon"]
